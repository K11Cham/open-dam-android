      "predictiveBackGestureEnabled": false,
      "package": "com.k11cham.dam"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "assets/*"
    ],
    "extra": {
      "eas": {
        "projectId": "b85645bf-af0e-4e03-9e97-e2d5a902645f"
